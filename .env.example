# Shiftboss Environment Configuration
# Copy this to .env and fill in your values
#
# All SHIFTBOSS_* variables also accept their legacy CONTROL_CENTER_* / PCC_*
# names, so existing .env files keep working without changes.

# =============================================================================
# REQUIRED
# =============================================================================

# OpenAI API key for Codex/LLM calls
OPENAI_API_KEY=your-api-key-here

# =============================================================================
# SERVER
# =============================================================================

# Shiftboss mode (local or cloud)
# SHIFTBOSS_MODE=local

# Database path (default: ./shiftboss.db; an existing ./control-center.db is
# picked up automatically for legacy installs)
# SHIFTBOSS_DB_PATH=./shiftboss.db

# Server port (default: 4010)
SHIFTBOSS_PORT=4010

# Server host (default: localhost)
SHIFTBOSS_HOST=localhost

# Repo root for scanning (overrides SHIFTBOSS_SCAN_ROOTS)
# SHIFTBOSS_REPOS_PATH=/path/to/repos

# Project directories to scan (comma-separated)
# SHIFTBOSS_SCAN_ROOTS=/path/to/projects

# =============================================================================
# CODEX / LLM
# =============================================================================

# Path to codex binary (default: searches PATH)
# SHIFTBOSS_CODEX_PATH=/usr/local/bin/codex

# Model for builder/reviewer (default: gpt-5.3-codex)
# SHIFTBOSS_CODEX_MODEL=gpt-5.3-codex

# Model for chat (default: same as CODEX_MODEL)
# SHIFTBOSS_CHAT_CODEX_MODEL=gpt-5.3-codex

# =============================================================================
# RUN LIMITS
# =============================================================================

# Max builder iterations per run phase (default: 10)
# SHIFTBOSS_MAX_BUILDER_ITERATIONS=10

# Max total run iterations (default: 10)
# SHIFTBOSS_MAX_RUN_ITERATIONS=10

# Remote test timeout in seconds (default: 900)
# SHIFTBOSS_REMOTE_TEST_TIMEOUT_SEC=900

# =============================================================================
# CORS / NETWORK
# =============================================================================

# Allow LAN connections (default: false)
# SHIFTBOSS_ALLOW_LAN=false

# Allow remote access to /health and /heartbeat without opening the full API
# SHIFTBOSS_ALLOW_REMOTE_HEALTH=false

# Optional shared token for health endpoints (query param `token` or `x-health-token` header)
# SHIFTBOSS_HEALTH_TOKEN=your-health-token

# Allow all CORS origins (default: false, use for dev only)
# SHIFTBOSS_CORS_ALLOW_ALL=false

# Allowed origins (comma-separated)
# SHIFTBOSS_ALLOWED_ORIGINS=http://localhost:5173

# =============================================================================
# ELEVENLABS / VOICE
# =============================================================================

# ElevenLabs agent ID for the landing page voice widget (client-side)
# NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-agent-id

# Data residency / server location for ElevenLabs conversations
# Options: us, eu-residency, in-residency, global
# NEXT_PUBLIC_ELEVENLABS_SERVER_LOCATION=us

# Shared secret for ElevenLabs webhook HMAC verification (server-side)
# SHIFTBOSS_ELEVENLABS_WEBHOOK_SECRET=your-webhook-secret

# ElevenLabs API key for minting signed URLs (server-side)
# SHIFTBOSS_ELEVENLABS_API_KEY=your-api-key

# ElevenLabs voice ID for ambient narration (server-side)
# SHIFTBOSS_ELEVENLABS_NARRATION_VOICE_ID=your-voice-id

# Optional narration model override (default: eleven_turbo_v2)
# SHIFTBOSS_ELEVENLABS_NARRATION_MODEL_ID=eleven_turbo_v2

# Signed URL TTL in seconds (default: 300)
# SHIFTBOSS_ELEVENLABS_SIGNED_URL_TTL_SECONDS=300

# =============================================================================
# SLACK
# =============================================================================

# Slack app credentials
# SHIFTBOSS_SLACK_CLIENT_ID=your-client-id
# SHIFTBOSS_SLACK_CLIENT_SECRET=your-client-secret
# SHIFTBOSS_SLACK_SIGNING_SECRET=your-signing-secret

# Optional redirect URI override (absolute URL)
# SHIFTBOSS_SLACK_REDIRECT_URI=https://your-host/slack/oauth/callback

# Optional scopes override (comma-separated)
# SHIFTBOSS_SLACK_SCOPES=chat:write,im:history,im:write,app_mentions:read,channels:history

# Conversation timeout in minutes (default: 10)
# SHIFTBOSS_SLACK_CONVERSATION_TIMEOUT_MINUTES=10

# Stale debrief rollover threshold in minutes (default: 30)
# SHIFTBOSS_SLACK_STALE_DEBRIEF_MINUTES=30

# High-risk approval expiry window in minutes (default: 30)
# SHIFTBOSS_SLACK_APPROVAL_TTL_MINUTES=30

# Enable Slack Operator V1 behavior (default: false)
# SHIFTBOSS_SLACK_OPERATOR_V1=false

# Comma-separated person IDs allowed to submit actionable Slack requests
# SHIFTBOSS_SLACK_OPERATOR_PERSON_IDS=person-id-1,person-id-2

# Comma-separated person IDs allowed to approve/unblock Slack operator access
# SHIFTBOSS_SLACK_APPROVER_PERSON_IDS=person-id-3,person-id-4

# =============================================================================
# SMS / TWILIO
# =============================================================================

# Twilio account SID + auth token for SMS
# SHIFTBOSS_TWILIO_ACCOUNT_SID=your-account-sid
# SHIFTBOSS_TWILIO_AUTH_TOKEN=your-auth-token
# SHIFTBOSS_TWILIO_PHONE_NUMBER=+15551234567

# Verify Twilio webhook signature (default: true)
# SHIFTBOSS_TWILIO_VERIFY_SIGNATURE=true

# Monthly SMS budget in cents (0 disables budget enforcement)
# SHIFTBOSS_SMS_MONTHLY_BUDGET_CENTS=500

# Rate limit per phone number per hour (default: 30)
# SHIFTBOSS_SMS_RATE_LIMIT_PER_HOUR=30

# Estimated cost per message in cents (default: 1)
# SHIFTBOSS_SMS_MESSAGE_COST_CENTS=1

# Conversation timeout in minutes (default: 30)
# SHIFTBOSS_SMS_CONVERSATION_TIMEOUT_MINUTES=30

# =============================================================================
# MEETING CONNECTOR / RECALL
# =============================================================================

# Recall.ai API key and auth header configuration
# SHIFTBOSS_RECALL_API_KEY=your-api-key
# SHIFTBOSS_RECALL_API_HEADER=Authorization
# SHIFTBOSS_RECALL_API_PREFIX=Bearer

# Optional extra headers as JSON (string values only)
# SHIFTBOSS_RECALL_HEADERS_JSON={"x-recall-org":"your-org"}

# Recall bot create URL + JSON body template
# Template placeholders: {meeting_url}, {bot_name}, {audio_ws_url},
# {audio_sample_rate}, {audio_channels}, {audio_sample_width}, {audio_frame_ms},
# {audio_format}
# SHIFTBOSS_RECALL_CREATE_URL=https://api.recall.ai/YOUR_CREATE_ENDPOINT
# SHIFTBOSS_RECALL_CREATE_BODY={"meeting_url":"{meeting_url}","bot_name":"{bot_name}","audio":{"type":"websocket","url":"{audio_ws_url}"}}

# Recall Output Media controls (optional)
# Template placeholders: {meeting_url}, {bot_id}, {bot_name}, {output_media_url}, {output_media_mode}
# SHIFTBOSS_RECALL_OUTPUT_MEDIA_URL=https://your-public-host/recall/screen-share
# SHIFTBOSS_RECALL_OUTPUT_MEDIA_START_URL=https://api.recall.ai/YOUR_OUTPUT_MEDIA_ENDPOINT
# SHIFTBOSS_RECALL_OUTPUT_MEDIA_START_METHOD=POST
# SHIFTBOSS_RECALL_OUTPUT_MEDIA_START_BODY={"bot_id":"{bot_id}","output_media":{"screen_share":{"config":{"url":"{output_media_url}","mode":"{output_media_mode}"}}}}
# SHIFTBOSS_RECALL_OUTPUT_MEDIA_STOP_URL=https://api.recall.ai/YOUR_OUTPUT_MEDIA_STOP_ENDPOINT/{bot_id}
# SHIFTBOSS_RECALL_OUTPUT_MEDIA_STOP_METHOD=POST
# SHIFTBOSS_RECALL_OUTPUT_MEDIA_STOP_BODY={"bot_id":"{bot_id}","output_media_id":"{output_media_id}"}

# Recall bot leave (optional)
# SHIFTBOSS_RECALL_LEAVE_URL=https://api.recall.ai/YOUR_LEAVE_ENDPOINT/{bot_id}
# SHIFTBOSS_RECALL_LEAVE_METHOD=POST
# SHIFTBOSS_RECALL_LEAVE_BODY={"bot_id":"{bot_id}"}

# Recall bot status polling (optional)
# SHIFTBOSS_RECALL_STATUS_URL=https://api.recall.ai/YOUR_STATUS_ENDPOINT/{bot_id}
# SHIFTBOSS_RECALL_STATUS_METHOD=GET

# Meeting audio WebSocket URL (publicly reachable by Recall.ai)
# SHIFTBOSS_MEETING_AUDIO_WS_URL=ws://your-host:8765

# Default meeting bot display name
# SHIFTBOSS_MEETING_BOT_NAME_DEFAULT=Shiftboss Agent

# Recall Output Media telemetry (disabled by default)
# RECALL_TELEMETRY_ENABLED=false
# RECALL_TELEMETRY_TOKEN=your-telemetry-token
# RECALL_TELEMETRY_LOG_PATH=/tmp/recall-output-media.jsonl
# NEXT_PUBLIC_RECALL_TELEMETRY_TOKEN=your-telemetry-token

# =============================================================================
# SCANNING
# =============================================================================

# Max depth for project scanning (default: 3)
# SHIFTBOSS_SCAN_MAX_DEPTH=3

# Scan cache TTL in milliseconds (default: 60000)
# SHIFTBOSS_SCAN_TTL_MS=60000

# Directories to ignore during scanning (comma-separated, added to defaults)
# SHIFTBOSS_IGNORE_DIRS=vendor,dist

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Use TypeScript worker directly (default: false, uses compiled JS)
# SHIFTBOSS_USE_TS_WORKER=false

# Mark in-progress runs as failed on server restart (default: false)
# SHIFTBOSS_FAIL_IN_PROGRESS_ON_RESTART=false
